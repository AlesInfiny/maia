# Web API のエンドポイントです。
VITE_AXIOS_BASE_ENDPOINT_ORIGIN=

# 開発環境において Web API をプロキシ経由で呼び出す際のエンドポイントです。
VITE_PROXY_ENDPOINT_ORIGIN=http://localhost:8080

# これより下はサンプルアプリケーション Dressca 固有の設定です。

# 商品画像が存在しない場合の代替画像の URL です。
VITE_NO_ASSET_URL=/api/assets/e622b0098808492cb883831c05486b58

# 商品画像が保存されているディレクトリの URL です。
VITE_ASSET_URL=/api/assets/

# https://{tenant_subdomain}.ciamlogin.com/
VITE_EXTERNAL_ID_AUTHORITY_DOMAIN=
# 設定したアクセス許可
VITE_EXTERNAL_ID_SCOPE=
# アプリケーションのクライアントID
VITE_EXTERNAL_ID_APP_CLIENT_ID=
# アプリケーションのリダイレクトURI
VITE_EXTERNAL_ID_REDIRECT_URI=
# アプリケーションのログアウトのリダイレクトURI
VITE_EXTERNAL_ID_LOGOUT_REDIRECT_URI=

# B2C_1_{ 『サインアップとサインイン』のユーザフロー名 }
VITE_ADB2C_USER_FLOW_SIGN_IN=
# { https://{初期ドメイン名}.b2clogin.com/{初期ドメイン名}.onmicrosoft.com/B2C_1_{『サインアップとサインイン』のユーザフロー名} }
VITE_ADB2C_SIGN_IN_URI=
# { {初期ドメイン名}.b2clogin.com }
VITE_ADB2C_AUTHORITY_DOMAIN=
# {APIの公開で設定したApplication ID URI}/{Web APIに追加したスコープの名前}
VITE_ADB2C_SCOPE=
# クライアントアプリケーションのクライアントID
VITE_ADB2C_APP_CLIENT_ID=
# アプリケーションのリダイレクトURI
VITE_ADB2C_REDIRECT_URI=