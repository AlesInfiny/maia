    "/api/display-items": {
      "get": {
        "description": "掲載品を検索して返します。",
        "operationId": "getByQuery",
        "parameters": [
          {
            "in": "query",
            "name": "brandId",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 0
            }
          },
          {
            "in": "query",
            "name": "categoryId",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 0
            }
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedListOfGetDisplayItemResponse"
                }
              }
            },
            "description": "成功。"
          },
          "400": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "リクエストエラー。"
          }
        },
        "summary": "掲載品を検索して返します。",
        "tags": [
          "DisplayItems"
        ]
      }
    },
    "/api/health": {
      "get": {
